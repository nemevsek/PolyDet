Cell["PolyDet", "GuideTitle",ExpressionUUID->"44708a26-3e81-493a-bb4e-8078d455850b"],

Cell[TextData[{
 "Renormalised one-loop fluctuation determinant and decay rate around a \
polygonal bounce (false-vacuum decay). A companion to FindBounce: it consumes \
a bounce and returns ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"ln", " "}], 
   SubscriptBox["det", "ren"]}]], "InlineFormula",ExpressionUUID->
  "09a0603f-9942-476e-8050-45af67684681"],
 ", or the complete multi-sector rate ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"ln", "("}], "\[CapitalGamma]", "/", 
   StyleBox["V",
    FontSlant->"Italic"], ")"}]], "InlineFormula",ExpressionUUID->
  "a63af642-c27b-428a-8cc8-95901cae1200"],
 ", via the transfer-matrix multipole sum with optimal-truncation \
acceleration and MS-bar renormalisation."
}], "GuideAbstract",ExpressionUUID->"164f03c2-85c7-4960-a0ca-02b881d8d20b"],

Cell[CellGroupData[{

Cell["Decay rate from a bounce", "GuideFunctionsSection",ExpressionUUID->"7026493e-0a45-448b-a216-3faaf32b7353"],

Cell[TextData[{
 Cell[BoxData[
  ButtonBox["PolyDetDecayRate",
   BaseStyle->"Link",
   ButtonData->"paclet:PolyDet/ref/PolyDetDecayRate"]], "InlineGuideFunction",
  ExpressionUUID->"7d577337-7bd2-4914-bf56-a5e5c131e5a1"],
 " \[LongDash] ",
 "complete one-loop rate ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"ln", "("}], "\[CapitalGamma]", "/", 
