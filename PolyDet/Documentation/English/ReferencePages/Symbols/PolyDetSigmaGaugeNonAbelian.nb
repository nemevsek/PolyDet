Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<FindBounce`\>\"", "]"}]], "Input",
 CellLabel->"In[2]:=",ExpressionUUID->"61f70ceb-a1c7-4c30-8b04-c9b765ec65a4"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"V", "[", "x_", "]"}], ":=", 
   RowBox[{
    RowBox[{
     FractionBox["1", "8"], " ", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox["x", "2"], "-", "1"}], ")"}], "2"]}], "+", 
    FractionBox[
     RowBox[{"x", "-", "1"}], "10"]}]}], ";"}]], "Input",
 CellLabel->"In[3]:=",ExpressionUUID->"9e186c44-d395-4033-a5ec-3e677e9eb548"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"tv", ",", "mid", ",", "fv"}], "}"}], "=", 
   RowBox[{"Sort", "[", 
    RowBox[{"Re", "[", 
     RowBox[{"x", "/.", "\[VeryThinSpace]", 
      RowBox[{"NSolve", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          SubscriptBox["\[PartialD]", "x"], 
          RowBox[{"V", "[", "x", "]"}]}], "\[Equal]", "0"}], ",", "x"}], 
       "]"}]}], "]"}], "]"}]}], ";", 
  RowBox[{"bf", "=", 
   RowBox[{"FindBounce", "[", 
    RowBox[{
     RowBox[{"V", "[", "x", "]"}], ",", "x", ",", 
     RowBox[{"{", 
      RowBox[{"fv", ",", "tv"}], "}"}], ",", 
     RowBox[{"FieldPoints", "\[Rule]", "9"}]}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[4]:=",ExpressionUUID->"f4ea5b33-a708-4162-914e-6e138f76c22d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"g", "=", 
   FractionBox["7", "10"]}], ";", 
  RowBox[{"gp", "=", 
   FractionBox["2", "5"]}], ";", 
  RowBox[{"Vaa", "=", 
   RowBox[{
    RowBox[{
     FractionBox["1", "2"], " ", 
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox["#1", "2"], "-", "1"}], ")"}]}], "&"}]}], 
  ";"}]], "Input",
 CellLabel->"In[5]:=",ExpressionUUID->"c1978855-43f1-493e-8c45-715efe5bb495"],

