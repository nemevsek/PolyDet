Cell["PolyDetSigmaGaugeNonAbelian", "ObjectName",ExpressionUUID->"80a3e001-0334-489a-a9c6-4d62683a9f9a"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{"PolyDetSigmaGaugeNonAbelian", "[", 
   RowBox[{
    StyleBox["bf", "TI"], ",", 
    StyleBox[Cell[BoxData[
      RowBox[{"{", "{", 
       SubscriptBox["g", "1"], ",", 
       SubscriptBox["n", "1"], "}", ",", "\[Ellipsis]", "}"}]], 
      "InlineFormula",ExpressionUUID->"b1c46761-4605-4f70-b1a1-640f67840325"],
      "TI"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "23e98060-08ca-47ed-8a6b-9504f117e220"],
 "\[LineSeparator]",
 "the non-Abelian gauge-boson determinant as a sum of Abelian ",
 Cell[BoxData[
  SubscriptBox["\[CapitalSigma]", "gauge"]], "InlineFormula",ExpressionUUID->
  "625cf9a4-619c-46ad-9bfa-39ec68e9780a"],
 " blocks: along a fixed bounce direction ",
 Cell[BoxData[
  SubsuperscriptBox["M", "A", "2"]], "InlineFormula",ExpressionUUID->
  "c09c2c8d-eca1-4096-9d48-847d2d34ce74"],
 " = C ",
 Cell[BoxData[
  SubscriptBox["\[Phi]", "b"]], "InlineFormula",ExpressionUUID->
  "3f71af07-ed02-44fd-9302-e52ea9b6f564"],
 Cell[BoxData[
 "\[VeryThinSpace]"], "InlineFormula",ExpressionUUID->
  "a7ce78cb-407d-4e54-8325-b8257968f90a"],
 " has a constant eigenbasis, so ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"ln", " "}], 
   SubscriptBox["det", "ren"]}]], "InlineFormula",ExpressionUUID->
  "d0494748-e786-4b14-8004-c6c1dcf70996"],
 " factorises into per-channel U(1) determinants with effective couplings ",
 Cell[BoxData[
  SubscriptBox["g", "a"]], "InlineFormula",ExpressionUUID->
  "5d9acec0-3942-4551-b9f6-21ad1b93c3e2"],
 " and multiplicities ",
 Cell[BoxData[
  SubscriptBox["n", "a"]], "InlineFormula",ExpressionUUID->
  "985d90ef-7319-4eb5-bc79-764cd3cef973"],
 " (massless ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["g", "a"], "=", "0"}]], "InlineFormula",ExpressionUUID->
  "f813ad01-4358-4338-90fc-cdd1146a2bee"],
 ", e.g. the photon, contribute 0). Returns ",
 Cell[BoxData[
  RowBox[{"\[LeftAssociation]", "\[CapitalSigma]", ",", 
   SubsuperscriptBox["I", "1", "eff"], ",", 
   SubsuperscriptBox["I", "3", "eff"], ",", 
   SubscriptBox["I", "g"], ",", 
   SubscriptBox["N", "sum"], "\[RightAssociation]"}]], "InlineFormula",
  ExpressionUUID->"65def13e-6051-4b65-8d34-6d9eecf2abbf"],
 " ",
 Cell[BoxData[
  RowBox[{"<|", "Sigma", ",", "Channels", "|>"}]], "InlineFormula",
  ExpressionUUID->"53b87cc3-2a49-45d1-a3d9-ced80d361e09"],
 ".",
 "\n"
}], "Usage",ExpressionUUID->"f898a358-f9ef-4eb2-bc42-1b7b1d16fca5"],

Cell[CellGroupData[{

Cell["Details and Options", "NotesSection",ExpressionUUID->"35d177ad-c92c-4d03-a618-00f540d3bd00"],

Cell[TextData[{
 "For a bounce along a fixed direction the gauge mass matrix ",
 Cell[BoxData[
  SubsuperscriptBox["M", "A", "2"]], "InlineFormula",ExpressionUUID->
  "7cb387ec-f1c5-4601-b5a8-3f420289d506"],
 " has a constant eigenbasis, so the determinant factorises into independent \
U(1) ",
 Cell[BoxData[
  SubscriptBox["\[CapitalSigma]", "gauge"]], "InlineFormula",ExpressionUUID->
  "7c0434ee-0ced-4d9c-9f38-2d4e1563a893"],
 " blocks \[LongDash] one per coupling eigenvalue ",
 Cell[BoxData[
  SubscriptBox["g", "a"]], "InlineFormula",ExpressionUUID->
  "0bd481b1-bd2d-43c3-a222-68c64e977474"],
 ", weighted by its multiplicity ",
 Cell[BoxData[
  SubscriptBox["n", "a"]], "InlineFormula",ExpressionUUID->
  "a7357617-6b9b-4e92-b4bc-db3e80a359e4"],
 "."
}], "Notes",ExpressionUUID->"96979940-5288-4c37-a242-57478698f738"],

Cell[TextData[{
 "Massless channels (",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["g", "a"], "=", "0"}]], "InlineFormula",ExpressionUUID->
  "c5385bd7-2607-4105-9d89-2abebe8c2617"],
 ", e.g. the photon) contribute 0. The group enters the rate only through the \
orbit volume ",
 Cell[BoxData[
  RowBox[{"Vol", "(", "G", "/", "H", ")"}]], "InlineFormula",ExpressionUUID->
  "c187ac24-1e45-40b0-b233-75781ee0a490"],
 "."
}], "Notes",ExpressionUUID->"65438a34-6282-42ca-a1da-ffc5eb204790"],

