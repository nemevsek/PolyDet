     StyleBox["Automatic", "InlineCode"]], "TableText",ExpressionUUID->
     "3250549d-46ac-4cf3-870a-a873e0ea4653"], Cell["\<\
the number of multipoles summed explicitly (Automatic: from Target, else ~5 \
x_max)\
\>", "TableText",ExpressionUUID->"4de06ec4-cd80-4bb3-a705-da8536f98d34"]},
   {Cell["", "ModInfo",ExpressionUUID->
     "6c553f97-0b82-4b86-8c00-d76a2189d0da"], Cell[BoxData[
