     "0eb92952-7589-4247-9c0e-69f7550dcae2"], Cell["\<\
the highest Laurent order subtracted in the optimal truncation\
\>", "TableText",ExpressionUUID->"e5a8daa1-35f6-4017-bcca-f6fdc3b07229"]},
   {Cell["", "ModInfo",ExpressionUUID->
     "d1b8cce7-294a-42fe-a3a7-53503a78d08b"], Cell[BoxData[
