Cell["PolyDetSigma", "ObjectName",ExpressionUUID->"82e650aa-9792-4109-a1f6-f361e7527cde"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{"PolyDetSigma", "[", 
   RowBox[{
    StyleBox["masses2", "TI"], ",", 
    StyleBox["radii", "TI"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "1f462fae-1d4a-47f0-9ae6-87bddd889ed6"],
 "\[LineSeparator]",
 "the subtracted (UV-regulated, finite) fluctuation-determinant sum ",
 Cell[BoxData[
  SubscriptBox["\[CapitalSigma]", "D"]], "InlineFormula",ExpressionUUID->
  "2d33ce45-ad15-41ac-bdf8-521d516242ef"],
 " by optimal truncation; add the regulated divergent orders with PolyDetRen.",
 "\n"
}], "Usage",ExpressionUUID->"49da1375-40ca-4f86-9c1c-2021483f08c4"],

Cell[CellGroupData[{

Cell["Details and Options", "NotesSection",ExpressionUUID->"552eb48e-74dc-4735-8f10-e06471d462ff"],

Cell[TextData[{
 "The subtracted, finite multipole sum: every order of the large-",
 Cell[BoxData[
 "\[Nu]"], "InlineFormula",ExpressionUUID->
  "a54fb87f-b363-4131-a209-d4ab411afe75"],
 " Laurent ",
 Cell[BoxData[
  SubscriptBox["I", "p"]], "InlineFormula",ExpressionUUID->
  "0c7c3ae5-c5cc-4a65-baca-88a7e13d6b32"],
 " is removed and the convergent part restored by a \[Zeta]-function add-back \
(optimal truncation)."
}], "Notes",ExpressionUUID->"c9cef130-514f-4e72-84e1-da055d7405aa"],

Cell["\<\
Not yet renormalised \[LongDash] the divergent orders are dropped; use \
PolyDetRen to put them back.\
\>", "Notes",ExpressionUUID->"54caf987-f35e-4617-8d86-a9a4d9c6bd58"],

Cell[BoxData[GridBox[{
   {Cell["", "ModInfo",ExpressionUUID->
     "624cce98-4f1c-403a-8c11-8a614941fb15"], Cell[BoxData[
     StyleBox["\"\<Dimension\>\"", "InlineCode"]], "TableText",ExpressionUUID->
     "26cea070-9d4e-466f-bafe-db5089241408"], Cell[BoxData[
     StyleBox["4", "InlineCode"]], "TableText",ExpressionUUID->
     "a76a62eb-6ffd-4393-8c71-c143e67740fc"], Cell[
    "the spacetime dimension D (3 or 4)", "TableText",ExpressionUUID->
     "f722e0c9-ada4-4c3f-93ca-bf869bf8d5c9"]},
   {Cell["", "ModInfo",ExpressionUUID->
     "51fa89b2-f2aa-49f4-a7b6-6c9bc5ad0de3"], Cell[BoxData[
