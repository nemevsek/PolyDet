   RowBox[{"{", 
    RowBox[{"1", ",", 
     RowBox[{"-", 
      FractionBox["1", "2"]}], ",", "2", ",", 
     FractionBox["13", "10"]}], "}"}]}], ";", 
  RowBox[{"r", "=", 
   RowBox[{"{", 
    RowBox[{"3", ",", "5", ",", "7"}], "}"}]}], ";"}]], "Input",
