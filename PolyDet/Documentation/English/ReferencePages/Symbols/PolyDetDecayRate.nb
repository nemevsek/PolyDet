Cell[CellGroupData[{

Cell["Examples", "PrimaryExamplesSection",ExpressionUUID->"a0ccb264-8af4-4e6b-a861-00366e28d061"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<PolyDet`\>\"", "]"}]], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"e109906c-6c07-4512-bec8-da9f157ea98f"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<FindBounce`\>\"", "]"}]], "Input",
 CellLabel->"In[2]:=",ExpressionUUID->"bf13d49a-4ab0-4b8f-9425-53f78f73fd6d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"V", "[", "x_", "]"}], ":=", 
   RowBox[{
    RowBox[{
     FractionBox["1", "8"], " ", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox["x", "2"], "-", "1"}], ")"}], "2"]}], "+", 
    FractionBox[
     RowBox[{"x", "-", "1"}], "10"]}]}], ";", 
  RowBox[{"Vpp", "=", 
   RowBox[{
    RowBox[{
     FractionBox["1", "2"], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"3", " ", 
        SuperscriptBox["#1", "2"]}], "-", "1"}], ")"}]}], "&"}]}], 
  ";"}]], "Input",
 CellLabel->"In[3]:=",ExpressionUUID->"2a9b88a4-8072-49d8-8d77-28f9478dd236"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"tv", ",", "mid", ",", "fv"}], "}"}], "=", 
   RowBox[{"Sort", "[", 
    RowBox[{"Re", "[", 
     RowBox[{"x", "/.", "\[VeryThinSpace]", 
      RowBox[{"NSolve", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          SubscriptBox["\[PartialD]", "x"], 
          RowBox[{"V", "[", "x", "]"}]}], "\[Equal]", "0"}], ",", "x"}], 
       "]"}]}], "]"}], "]"}]}], ";", 
  RowBox[{"bf", "=", 
   RowBox[{"FindBounce", "[", 
    RowBox[{
     RowBox[{"V", "[", "x", "]"}], ",", "x", ",", 
     RowBox[{"{", 
      RowBox[{"fv", ",", "tv"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[4]:=",ExpressionUUID->"9731ba10-bdd3-4198-9ae0-bdb9f1362577"],

Cell[BoxData[
 RowBox[{
  RowBox[{"sectors", "=", 
   RowBox[{"{", 
    RowBox[{"Association", "[", 
     RowBox[{
      RowBox[{"\"\<Type\>\"", "\[Rule]", "\"\<Scalar\>\""}], ",", 
      RowBox[{"\"\<Mass2\>\"", "\[Rule]", 
       RowBox[{"Function", "[", 
        RowBox[{"ph", ",", 
         RowBox[{
          FractionBox["1", "2"], "+", 
          FractionBox[
           RowBox[{"4", " ", 
            SuperscriptBox["ph", "2"]}], "5"]}]}], "]"}]}]}], "]"}], "}"}]}], 
  ";"}]], "Input",
 CellLabel->"In[5]:=",ExpressionUUID->"d17b514c-8a20-4a4e-8617-755c46778b9c"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<FindBounce`\>\"", "]"}]], "Input",
 CellLabel->"In[6]:=",ExpressionUUID->"f81262df-7f6c-45a5-9501-44bf18d6a86b"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Uu", "[", "s_", "]"}], ":=", 
   RowBox[{
    RowBox[{"6", " ", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"s", "-", 
        FractionBox["2", "25"]}], ")"}], "2"], " ", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"s", "-", 
        FractionBox["18", "25"]}], ")"}], "2"]}], "-", 
    RowBox[{
     FractionBox["3", "25"], " ", 
     RowBox[{"(", 
      RowBox[{"s", "-", 
       FractionBox["2", "25"]}], ")"}]}]}]}], ";"}]], "Input",
 CellLabel->"In[7]:=",ExpressionUUID->"f0d916d8-ce96-4cba-a538-195024f44591"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"VuU", "[", "ph_", "]"}], ":=", 
   RowBox[{"Uu", "[", 
    FractionBox[
     SuperscriptBox["ph", "2"], "2"], "]"}]}], ";", 
  RowBox[{"VppU", "=", 
   RowBox[{
    RowBox[{
     SuperscriptBox["VuU", "\[Prime]\[Prime]",
      MultilineFunction->None], "[", "#1", "]"}], "&"}]}], ";", 
  RowBox[{"VaaU", "=", 
   RowBox[{
    FractionBox[
     RowBox[{
      SuperscriptBox["VuU", "\[Prime]",
       MultilineFunction->None], "[", "#1", "]"}], "#1"], "&"}]}], ";", 
  RowBox[{"gU", "=", 
   FractionBox["7", "10"]}], ";"}]], "Input",
 CellLabel->"In[8]:=",ExpressionUUID->"fdd0e5ad-c86e-4ca2-855a-cd31312361d7"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"fvU", ",", "tvU"}], "}"}], "=", 
   RowBox[{"MinMax", "[", 
    RowBox[{"ph", "/.", "\[VeryThinSpace]", 
     RowBox[{"Solve", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{
           SuperscriptBox["VuU", "\[Prime]",
            MultilineFunction->None], "[", "ph", "]"}], "\[Equal]", "0"}], 
         ",", 
         RowBox[{"ph", ">", "0"}]}], "}"}], ",", "ph", ",", 
       TemplateBox[{},
        "Reals"]}], "]"}]}], "]"}]}], ";", 
  RowBox[{"bfU", "=", 
   RowBox[{"FindBounce", "[", 
    RowBox[{
     RowBox[{"VuU", "[", "ph", "]"}], ",", "ph", ",", 
     RowBox[{"{", 
      RowBox[{"fvU", ",", "tvU"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[9]:=",ExpressionUUID->"3ba4eb61-604a-4a24-8047-48c3a9bfe965"],

Cell[BoxData[
 RowBox[{"PolyDetDecayRate", "[", 
  RowBox[{"Vpp", ",", "bf", ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Association", "[", 
      RowBox[{
       RowBox[{"\"\<Type\>\"", "\[Rule]", "\"\<Fermion\>\""}], ",", 
       RowBox[{"\"\<Mass\>\"", "\[Rule]", 
        RowBox[{"Function", "[", 
         RowBox[{"ph", ",", "ph"}], "]"}]}], ",", 
       RowBox[{"\"\<Mult\>\"", "\[Rule]", "3"}]}], "]"}], ",", 
     RowBox[{"Association", "[", 
      RowBox[{
       RowBox[{"\"\<Type\>\"", "\[Rule]", "\"\<Scalar\>\""}], ",", 
       RowBox[{"\"\<Mass2\>\"", "\[Rule]", 
        RowBox[{"Function", "[", 
         RowBox[{"ph", ",", 
          RowBox[{
           FractionBox["1", "2"], "+", 
           FractionBox[
            RowBox[{"4", " ", 
             SuperscriptBox["ph", "2"]}], "5"]}]}], "]"}]}]}], "]"}]}], 
    "}"}]}], "]"}]], "Input",
 CellLabel->"In[10]:=",ExpressionUUID->"86cbc800-4618-44f3-b3bb-20301b888cef"],

Cell[BoxData[
 RowBox[{"PolyDetDecayRate", "[", 
  RowBox[{"Vpp", ",", "bf", ",", "sectors", ",", 
   RowBox[{"\"\<Breakdown\>\"", "\[Rule]", "True"}]}], "]"}]], "Input",
 CellLabel->"In[11]:=",ExpressionUUID->"9dbe41c2-2800-495a-8808-016e8804ba0f"]
}, Open  ]],

