Cell["PolyDetDecayRate", "ObjectName",ExpressionUUID->"00eeda81-b483-477a-bd23-f7ba9fc71b79"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{"PolyDetDecayRate", "[", 
   RowBox[{
    StyleBox["Vpp", "TI"], ",", 
    StyleBox["bf", "TI"], ",", 
    StyleBox["extra", "TI"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "020c251d-67c2-4254-9489-a7b10aafd56b"],
 "\[LineSeparator]",
 "the COMPLETE one-loop decay rate ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"ln", "("}], "\[CapitalGamma]", "/", 
   StyleBox["V",
    FontSlant->"Italic"], ")"}]], "InlineFormula",ExpressionUUID->
  "c8e018f9-3042-45d8-939e-6e3c5a97005d"],
 " from a FindBounce BounceFunction ",
 StyleBox["bf",
  FontSlant->"Italic"],
 ": the driving Higgs scalar (V'' = ",
 StyleBox["Vpp",
  FontSlant->"Italic"],
 ", translational zero modes removed) plus a list of ",
 StyleBox["extra",
  FontSlant->"Italic"],
 " field sectors, assembled with the one-loop signs (scalar +, gauge +, \
fermion \[Minus]) at one shared ",
 Cell[BoxData[
 "\[Mu]"], "InlineFormula",ExpressionUUID->
  "007feb14-8977-4bda-a68e-ae5553eb581f"],
 ". Each sector is an Association tagged ",
 StyleBox["\"Scalar\"",
  FontSlant->"Italic"],
 " / ",
 StyleBox["\"Fermion\"",
  FontSlant->"Italic"],
 " / ",
 StyleBox["\"Gauge\"",
  FontSlant->"Italic"],
 ".",
 "\n"
}], "Usage",ExpressionUUID->"c84d9709-3d05-42ed-afe6-21353c4ab1c2"],

Cell[CellGroupData[{

Cell["Details and Options", "NotesSection",ExpressionUUID->"1f23d167-3b24-4ef3-839d-f94d6bd0b4bf"],

Cell[TextData[{
 "Assembles every sector with the correct one-loop sign \[LongDash] scalars \
and gauge bosons add, Dirac fermions subtract (the ",
 Cell[BoxData[
  SuperscriptBox[
   RowBox[{"(", 
    RowBox[{"-", "1"}], ")"}], "F"]], "InlineFormula",ExpressionUUID->
  "fecf14bf-7684-43d4-8cd3-5af9148b0db0"],
 " sign) \[LongDash] into a single ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"ln", "("}], "\[CapitalGamma]", "/", 
   StyleBox["V",
    FontSlant->"Italic"], ")"}]], "InlineFormula",ExpressionUUID->
  "b73cae7b-327c-41de-8244-3f2966728a2b"],
 " at one shared scale \[Mu]."
}], "Notes",ExpressionUUID->"0bfe9ec6-d6c7-49d4-9372-fe2e96ebeb80"],

Cell[TextData[{
 "The driving Higgs scalar (second derivative ",
 StyleBox["Vpp",
  FontSlant->"Italic"],
 ") carries the translational zero modes, removed automatically."
}], "Notes",ExpressionUUID->"22ab3ca7-ba34-404e-ad08-8211b7b90594"],

Cell[BoxData[GridBox[{
   {Cell["", "ModInfo",ExpressionUUID->
     "e1c6bd44-0cb8-47a6-a6a5-fc533d52a7eb"], Cell[BoxData[
     StyleBox["\"\<Scale\>\"", "InlineCode"]], "TableText",ExpressionUUID->
