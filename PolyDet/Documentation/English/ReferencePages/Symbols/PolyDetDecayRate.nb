Cell[BoxData[
 RowBox[{"PolyDetDecayRate", "[", 
  RowBox[{"Vpp", ",", "bf", ",", "sectors", ",", 
   RowBox[{"\"\<Scale\>\"", "\[Rule]", "2"}]}], "]"}]], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"2fb815eb-d6ba-4e86-83fb-acd7c7784c91"],

Cell["Interactive Examples", "ExampleSection",ExpressionUUID->"f498f341-0304-4345-899f-18444ee51393"],

Cell[TextData[{
 "Drag the blue ",
 StyleBox["Locator",
  FontSlant->"Italic"],
 " points to reshape the potential V(\[CurlyPhi]); the bounce action and the \
decay rate ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"ln", "("}], "\[CapitalGamma]", "/", 
   StyleBox["V",
    FontSlant->"Italic"], ")"}]], "InlineFormula",ExpressionUUID->
  "47eaf56a-a254-4ee6-8b46-566da338cb7e"],
 " recompute live. A smooth degree-4 fit of the points supplies the curvature \
V'' the determinant needs, while ",
 StyleBox["FindBounce",
  FontSlant->"Italic"],
 " builds the polygonal bounce (needs ",
 StyleBox["FindBounce`",
  FontSlant->"Italic"],
 " loaded)."
}], "ExampleText",ExpressionUUID->"fc12e9c3-276d-407f-8494-43898862da45"],

Cell["\<\
DynamicModule[{pts = {{-1.3, 0.}, {-0.6, 0.45}, {0., 0.5}, {0.6, 0.25}, {1.3, \
-0.35}}}, Framed[Row[{LocatorPane[Dynamic[pts], Dynamic[Module[{sp = \
SortBy[pts, First], vf, x}, vf = Fit[sp, Table[x^k, {k, 0, 4}], x]; \
Show[Plot[vf, {x, -1.7, 1.7}, PlotStyle -> Directive[Darker[Orange], Thick], \
PlotRange -> All], Graphics[{Blue, Thick, Line[sp]}], Frame -> True, \
PlotRange -> {{-1.7, 1.7}, {-0.4, 1.}}, FrameLabel -> {\"\[CurlyPhi]\", \"V(\
\[CurlyPhi])\"}, ImageSize -> {Automatic, 240}, PlotLabel -> \"drag the \
points\"]]], LocatorAutoCreate -> True], Spacer[14], Dynamic[Module[{sp = \
SortBy[pts, First], bf, vf, Vpp, rate, x}, bf = Quiet[FindBounce[sp]]; \
If[Head[bf] =!= BounceFunction ||  !NumericQ[bf[\"Action\"]] || \
Re[bf[\"Action\"]] <= 0, Framed[Style[\"no metastable bounce \[LongDash] make \
a barrier\", Gray, 14], ImageSize -> {340, 240}, Alignment -> Center], vf = \
Fit[sp, Table[x^k, {k, 0, 4}], x]; Vpp = Function[ph, Evaluate[D[vf, {x, 2}] \
/. x -> ph]]; rate = Quiet[PolyDetDecayRate[Vpp, bf, {}, \"Target\" -> \
0.05]]; Column[{BouncePlot[bf, PerformanceGoal -> \"Speed\", ImageSize -> \
{Automatic, 190}, PlotStyle -> Darker[Yellow, 0.2]], Grid[{{Subscript[\"S\", \
\"0\"], NumberForm[bf[\"Action\"], 6]}, {\"ln(\[CapitalGamma]/V)\", \
Style[NumberForm[Re[rate], 6], Bold]}}, Alignment -> {{Right, Left}}, Frame \
-> All, BaseStyle -> {FontSize -> 13}]}]]], SynchronousUpdating -> False]}, \
Alignment -> Top]]]\
\>", "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"a0b7d4ff-9b6d-46cf-8351-14f4bdf47fa6"]
}, Open  ]]
},
