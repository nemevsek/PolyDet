Cell["Applications", "ExampleSection",ExpressionUUID->"e8d46184-d2c7-488e-b908-ddcc006788a6"],

Cell[TextData[{
 "The genuine ",
 "U(1)",
 " Abelian-Higgs decay rate: the driving (radial Higgs) scalar plus a gauge \
sector built from the same model. The would-be Goldstone is part of the gauge \
block; ",
 StyleBox["VppU",
  FontSlant->"Italic"],
 " is the radial second derivative and ",
 StyleBox["VaaU",
  FontSlant->"Italic"],
 " the genuine angular curvature, both from the smooth ",
 Cell[BoxData[
  RowBox[{
   StyleBox["V",
    FontSlant->"Italic"], "=", 
   StyleBox["U",
    FontSlant->"Italic"], "(", "\[Sigma]", ")"}]], "InlineFormula",
  ExpressionUUID->"9281d24b-2e3d-48bf-98af-a564c9422bf7"],
 ". The result is the complete one-loop ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"ln", "("}], "\[CapitalGamma]", "/", 
   StyleBox["V",
    FontSlant->"Italic"], ")"}]], "InlineFormula",ExpressionUUID->
  "12658cc0-3d3e-4822-a7ec-f43feaa703e3"],
 " (Higgs ",
 Cell[BoxData[
 "+"], "InlineFormula",ExpressionUUID->"4ddbd092-5fc0-4dba-82fd-3a485ca95d22"],
 " gauge):"
}], "ExampleText",ExpressionUUID->"fd8d5591-8c98-4912-ab69-1cf204494e44"],

Cell[BoxData[
 RowBox[{"PolyDetDecayRate", "[", 
  RowBox[{"VppU", ",", "bfU", ",", 
   RowBox[{"{", 
    RowBox[{"Association", "[", 
     RowBox[{
      RowBox[{"\"\<Type\>\"", "\[Rule]", "\"\<Gauge\>\""}], ",", 
      RowBox[{"\"\<Coupling\>\"", "\[Rule]", "gU"}], ",", 
      RowBox[{"\"\<Vaa\>\"", "\[Rule]", "VaaU"}]}], "]"}], "}"}], ",", 
   RowBox[{"\"\<Ig\>\"", "\[Rule]", 
    RowBox[{"-", 
     FractionBox["277", "10"]}]}]}], "]"}]], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"309130aa-402f-4fa1-827c-1120a3afa82a"],

Cell["Options", "ExampleSection",ExpressionUUID->"f7fef632-ac47-412b-ad6e-abf34dbf1b77"],

Cell["Inspect the per-sector pieces:", "ExampleText",ExpressionUUID->"724542d9-ea14-4910-8287-5413202a3d4d"],

