Cell["PolyDetRen", "ObjectName",ExpressionUUID->"25f9596e-b81a-40de-a45a-a898e24f8127"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{"PolyDetRen", "[", 
   RowBox[{
    StyleBox["masses2", "TI"], ",", 
    StyleBox["radii", "TI"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0ecfe2f8-ab9d-498c-b61a-d5f8a5329992"],
 "\[LineSeparator]",
 "the renormalised one-loop determinant ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"ln", " "}], 
   SubscriptBox["det", "ren"]}]], "InlineFormula",ExpressionUUID->
  "06f56ed7-e643-43a7-81f8-9827afe7ee08"],
 " = ",
 Cell[BoxData[
  SubscriptBox["\[CapitalSigma]", "D"]], "InlineFormula",ExpressionUUID->
  "d5362019-8629-4237-a19a-f1aa53ab4b10"],
 " + ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[Delta]", "ct"], "(", "\[Mu]", ")"}]], "InlineFormula",
  ExpressionUUID->"b0adae0a-17bc-448c-a665-337f223a368d"],
 " around a polygonal bounce with segment squared-masses ",
 StyleBox["masses2",
  FontSlant->"Italic"],
 " and matching ",
 StyleBox["radii",
  FontSlant->"Italic"],
 " (",
 Cell[BoxData[
  StyleBox["D",
   FontSlant->"Italic"]], "InlineFormula",ExpressionUUID->
  "52dac44b-61e6-4c72-9337-84dfc2105258"],
 " = 3, 4; ",
 Cell[BoxData[
  RowBox[{
   StyleBox["l",
    FontSlant->"Italic"], "=", "1"}]], "InlineFormula",ExpressionUUID->
  "31d30be7-3c3d-4ea5-bad5-8bb3e8ef872e"],
 " zero modes removed by default).",
 "\n"
}], "Usage",ExpressionUUID->"ca448ab8-906b-43bb-be79-1ecd55bb4e43"],

Cell[CellGroupData[{

Cell["Details and Options", "NotesSection",ExpressionUUID->"994805f3-ac8e-4cbb-ba89-e658679dacf1"],

Cell[TextData[{
 "Restores the regulated divergent orders to the subtracted sum ",
 Cell[BoxData[
  SubscriptBox["\[CapitalSigma]", "D"]], "InlineFormula",ExpressionUUID->
  "1c2c341e-16fa-41de-a237-8fcccf29e1e8"],
 ": in ",
 Cell[BoxData[
  StyleBox["D",
   FontSlant->"Italic"]], "InlineFormula",ExpressionUUID->
  "4bbeb5a7-48cc-4720-91c5-5a9ba5787142"],
 " = 4 the ",
 Cell[BoxData[
  SubscriptBox["I", "3"]], "InlineFormula",ExpressionUUID->
  "80a10281-1016-43a0-8034-0d5da9d629d7"],
 " logarithmic counterterm (MS-bar), in ",
 Cell[BoxData[
  StyleBox["D",
   FontSlant->"Italic"]], "InlineFormula",ExpressionUUID->
  "fbfe9b9d-56e8-49f2-b212-4daa8cfd902b"],
 " = 3 a finite, \[Mu]-independent result."
}], "Notes",ExpressionUUID->"08bf4f21-14e1-4abd-ba3a-71c9f5215546"],

Cell[TextData[{
 "The ",
 Cell[BoxData[
  RowBox[{
   StyleBox["l",
    FontSlant->"Italic"], "=", "1"}]], "InlineFormula",ExpressionUUID->
  "ca98954e-b7d4-4165-8eac-56f6e0d02f16"],
 " translational zero modes are removed by default; the artifact term is \
replaced by ",
 Cell[BoxData[
  SubsuperscriptBox["R", "1", "\[Prime]"]], "InlineFormula",ExpressionUUID->
  "6f95e301-6ddd-47fb-8e1f-1866c7e2302a"],
 "."
}], "Notes",ExpressionUUID->"223747b9-d395-432d-9e5b-6d095f1c7783"],

