  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f867aaf9-8126-405c-9e21-604add868ecd"],
 "\[LineSeparator]",
 "extracts ",
 Cell[BoxData[
  RowBox[{"{", 
   StyleBox["masses2",
    FontSlant->"Italic"], ",", 
   StyleBox["radii",
    FontSlant->"Italic"], "}"}]], "InlineFormula",ExpressionUUID->
  "cbb990eb-2ae3-4887-b421-1bf547c04d1f"],
 " from a FindBounce BounceFunction ",
 StyleBox["bf",
  FontSlant->"Italic"],
 ": segment-averaged ",
 StyleBox["Vpp",
  FontSlant->"Italic"],
 " = V''(",
 "\[Phi]",
 ") on the polygon, radii from ",
