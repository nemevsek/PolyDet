     "d3991f31-5216-444f-b220-82ba9e9c4dc7"], Cell["\<\
the target relative accuracy, which sets Nsum via the nu_max law\
\>", "TableText",ExpressionUUID->"c763013f-2eb4-45f3-9920-ed390d04b304"]},
   {Cell["", "ModInfo",ExpressionUUID->
     "3f426ff0-9cbe-41d2-abd0-c626060d0d47"], Cell[BoxData[
     StyleBox["\"\<NuMin\>\"", "InlineCode"]], "TableText",ExpressionUUID->
     "e681b600-efba-4cfa-9b70-264595e39b2c"], Cell[BoxData[
