Cell["PolyDet", "ObjectName",ExpressionUUID->"b882cacb-5f15-49d1-8af7-7832824af0a2"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{"PolyDet", "[", 
   RowBox[{
    StyleBox["V", "TI"], ",", 
    StyleBox["field", "TI"], ",", 
    StyleBox["bf", "TI"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "139659f1-2e64-41a2-b3d4-403bc57aa297"],
 "\[LineSeparator]",
 "the renormalised determinant ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"ln", " "}], 
   SubscriptBox["det", "ren"]}]], "InlineFormula",ExpressionUUID->
  "f3b94698-0119-4617-a326-c62010f6f2ba"],
 " directly from a FindBounce BounceFunction ",
 StyleBox["bf",
  FontSlant->"Italic"],
 " for the potential ",
 StyleBox["V",
  FontSlant->"Italic"],
 " in variable ",
 StyleBox["field",
  FontSlant->"Italic"],
 " (extracts the inputs and reads ",
 Cell[BoxData[
  StyleBox["D",
   FontSlant->"Italic"]], "InlineFormula",ExpressionUUID->
  "c691198a-e14e-43b4-83ef-0dc05cffdbdd"],
 " from ",
 StyleBox["bf",
  FontSlant->"Italic"],
 ").",
 "\n"
}], "Usage",ExpressionUUID->"1330891c-8ba2-42f5-8865-5755546ae51a"],

Cell[CellGroupData[{

Cell["Details and Options", "NotesSection",ExpressionUUID->"75d3d13a-785d-45e0-9394-5c7c829fd876"],

Cell[TextData[{
 "The one-call scalar workflow: differentiates the potential ",
 StyleBox["V",
  FontSlant->"Italic"],
 ", extracts the polygonal masses and radii with PolyDetInputs, and \
renormalises with PolyDetRen (reading ",
 Cell[BoxData[
  StyleBox["D",
   FontSlant->"Italic"]], "InlineFormula",ExpressionUUID->
  "1d517429-ca06-4392-afe5-37b8a9b2f824"],
 " from ",
 StyleBox["bf",
  FontSlant->"Italic"],
 "). PolyDetRen / PolyDetSigma options pass through."
}], "Notes",ExpressionUUID->"8ed3c73b-1708-4f9a-abc5-196b320b12a2"],

Cell[BoxData[GridBox[{
   {Cell["", "ModInfo",ExpressionUUID->
     "8147739f-c510-427b-8af6-7290aa7383f4"], Cell[BoxData[
     StyleBox["\"\<Scale\>\"", "InlineCode"]], "TableText",ExpressionUUID->
     "30d164df-74db-4ce2-b168-4605abdae699"], Cell[BoxData[
     StyleBox["1", "InlineCode"]], "TableText",ExpressionUUID->
     "9795ca6c-5ded-481e-9e89-9526b35adcb9"], Cell[
    "the MS-bar renormalisation scale mu", "TableText",ExpressionUUID->
     "9de52a54-778f-4c25-8872-eef8582522db"]},
   {Cell["", "ModInfo",ExpressionUUID->
     "863593d7-6c3e-4d39-b335-36d27c5402c6"], Cell[BoxData[
     StyleBox["\"\<ZeroRemoval\>\"", "InlineCode"]], "TableText",
     ExpressionUUID->"399bebf3-b833-48fc-9b92-4e867d54b50b"], Cell[BoxData[
     StyleBox["True", "InlineCode"]], "TableText",ExpressionUUID->
     "8ac2c555-6a8d-4c6c-a3d7-16afc8210f2d"], Cell["\<\
remove the l=1 translational zero modes (via the reduced ratio R_1')\
\>", "TableText",ExpressionUUID->"a167bd2c-61ca-49e2-a043-d15fd58e9fc0"]},
   {Cell["", "ModInfo",ExpressionUUID->
     "9f13f1d5-08c8-41ba-a4de-d9ec3b2d2438"], Cell[BoxData[
     StyleBox["\"\<Dimension\>\"", "InlineCode"]], "TableText",ExpressionUUID->
     "bab83bc8-2c69-44d2-b5be-5367f9357a77"], Cell[BoxData[
     StyleBox["4", "InlineCode"]], "TableText",ExpressionUUID->
     "5e8ff5e3-7782-4c82-be23-f0a0e2eb0044"], Cell[
    "the spacetime dimension D (3 or 4)", "TableText",ExpressionUUID->
     "a7276f1f-77e7-4fce-861e-a8e313419039"]},
   {Cell["", "ModInfo",ExpressionUUID->
     "6a2b2b68-0ea5-4581-b37f-801042805148"], Cell[BoxData[
     StyleBox["WorkingPrecision", "InlineCode"]], "TableText",ExpressionUUID->
     "59befe80-9e2e-4465-a2c4-3d6bcb487f88"], Cell[BoxData[
     StyleBox["Automatic", "InlineCode"]], "TableText",ExpressionUUID->
     "ab7422a2-e649-4854-8121-2683ffa90789"], Cell["\<\
the working precision (Automatic chooses machine vs scaled arbitrary \
precision)\
\>", "TableText",ExpressionUUID->"b52f1e0a-8600-4d76-8bf3-f5462e90375e"]},
   {Cell["", "ModInfo",ExpressionUUID->
     "e23bfbf0-6a4c-46b8-97cf-81e5b043c209"], Cell[BoxData[
     StyleBox["\"\<Nsum\>\"", "InlineCode"]], "TableText",ExpressionUUID->
     "16cf07ba-09a7-4ea2-accd-ffdb98241ada"], Cell[BoxData[
     StyleBox["Automatic", "InlineCode"]], "TableText",ExpressionUUID->
     "a045dcee-0e95-4672-bc87-ef62b16fe623"], Cell["\<\
the number of multipoles summed explicitly (Automatic: from Target, else ~5 \
x_max)\
\>", "TableText",ExpressionUUID->"9444beaf-7357-469a-a09e-c67ef02064d2"]},
   {Cell["", "ModInfo",ExpressionUUID->
     "ddf7bd52-a653-49ef-9b08-d4e5f366c4d7"], Cell[BoxData[
     StyleBox["\"\<Pmax\>\"", "InlineCode"]], "TableText",ExpressionUUID->
     "ff404b58-a26d-4fc2-b5b4-54e829b75de2"], Cell[BoxData[
     StyleBox["11", "InlineCode"]], "TableText",ExpressionUUID->
     "a8c572de-85d8-4aef-a648-c973b0c7a522"], Cell["\<\
the highest Laurent order subtracted in the optimal truncation\
\>", "TableText",ExpressionUUID->"1ccf94f4-6399-488e-8883-dba5fdf063b6"]},
   {Cell["", "ModInfo",ExpressionUUID->
     "47c7b4ab-e7c4-46ef-9b4e-cdcc3c3fccf7"], Cell[BoxData[
