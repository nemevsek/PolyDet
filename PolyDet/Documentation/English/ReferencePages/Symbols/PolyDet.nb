Cell[CellGroupData[{

Cell["Examples", "PrimaryExamplesSection",ExpressionUUID->"9e1a5257-88f8-4666-b24b-021166a9fe4a"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<PolyDet`\>\"", "]"}]], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"e23c2726-c682-4145-ba12-a17871b3f40c"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<FindBounce`\>\"", "]"}]], "Input",
 CellLabel->"In[2]:=",ExpressionUUID->"c5753249-9a56-46ce-bb19-d8be36d17343"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"V", "[", "x_", "]"}], ":=", 
   RowBox[{
    RowBox[{
     FractionBox["1", "8"], " ", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox["x", "2"], "-", "1"}], ")"}], "2"]}], "+", 
    FractionBox[
     RowBox[{"x", "-", "1"}], "10"]}]}], ";", 
  RowBox[{"Vpp", "=", 
   RowBox[{
    RowBox[{
     FractionBox["1", "2"], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"3", " ", 
        SuperscriptBox["#1", "2"]}], "-", "1"}], ")"}]}], "&"}]}], 
  ";"}]], "Input",
 CellLabel->"In[3]:=",ExpressionUUID->"a1293747-9c40-487a-bc7d-42680db8c71f"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"tv", ",", "mid", ",", "fv"}], "}"}], "=", 
   RowBox[{"Sort", "[", 
    RowBox[{"Re", "[", 
     RowBox[{"x", "/.", "\[VeryThinSpace]", 
      RowBox[{"NSolve", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          SubscriptBox["\[PartialD]", "x"], 
          RowBox[{"V", "[", "x", "]"}]}], "\[Equal]", "0"}], ",", "x"}], 
       "]"}]}], "]"}], "]"}]}], ";", 
  RowBox[{"bf", "=", 
   RowBox[{"FindBounce", "[", 
    RowBox[{
     RowBox[{"V", "[", "x", "]"}], ",", "x", ",", 
     RowBox[{"{", 
      RowBox[{"fv", ",", "tv"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[4]:=",ExpressionUUID->"18641521-7b29-4ea7-ab94-f3885e7bf19e"],

Cell[BoxData[
 RowBox[{"PolyDet", "[", 
  RowBox[{
   RowBox[{"V", "[", "x", "]"}], ",", "x", ",", "bf"}], "]"}]], "Input",
 CellLabel->"In[5]:=",ExpressionUUID->"c5c49125-2fcd-4ff8-956d-3f658b5af9fe"]
}, Open  ]],

