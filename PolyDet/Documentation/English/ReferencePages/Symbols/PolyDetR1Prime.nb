  SubsuperscriptBox["R", "1", "\[Prime]"]], "InlineFormula",ExpressionUUID->
  "bd111259-b84d-489e-b7c1-20eea3086598"],
 " that replaces the removed translational zero mode (",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["R", 
    RowBox[{
     StyleBox["l",
      FontSlant->"Italic"], "=", "1"}]], "=", "0"}]], "InlineFormula",
  ExpressionUUID->"a0c0f152-5c5f-406e-82de-2af43649cc10"],
 ", ",
