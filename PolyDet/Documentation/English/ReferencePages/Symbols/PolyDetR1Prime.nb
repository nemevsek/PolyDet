  "933ab20f-6de5-4dc5-aba6-9c3dfabccecc"],
 "); ",
 "\[RightArrow] ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["e", 
    RowBox[{
     StyleBox["D",
      FontSlant->"Italic"], "-", "1"}]], 
   RowBox[{"/", "12"}]}]], "InlineFormula",ExpressionUUID->
  "46b492c4-e2d4-433c-a215-e092169ada5a"],
 " in the thin-wall limit.",
 "\n"
}], "Usage",ExpressionUUID->"3e9ecc4e-735b-4586-a940-2cb66dc72431"],

