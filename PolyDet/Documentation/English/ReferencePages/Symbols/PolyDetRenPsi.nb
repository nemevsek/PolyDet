Cell["PolyDetRenPsi", "ObjectName",ExpressionUUID->"53378fff-8ad7-48dc-a287-86db0d3ab2e8"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{"PolyDetRenPsi", "[", 
   RowBox[{
    StyleBox["masses", "TI"], ",", 
    StyleBox["radii", "TI"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a8ed6b7d-7839-4daf-b610-e5ab0e7cca50"],
 "\[LineSeparator]",
 "the renormalised one-loop Dirac-fermion (Yukawa) determinant with signed \
real shell masses ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["M", "s"], "=", "m", "+", 
   RowBox[{"y", "\[ThinSpace]"}], 
   SubscriptBox["\[Phi]", "s"]}]], "InlineFormula",ExpressionUUID->
  "afad698b-335a-42d7-ad93-e039d80262f7"],
 "; running ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["\[Beta]", "\[Psi]"], "=", 
   SubsuperscriptBox["I", "2", "\[Psi]"], "+", 
   SubsuperscriptBox["I", "3", "\[Psi]"]}]], "InlineFormula",ExpressionUUID->
  "8d2f6449-292c-49cd-b217-d4167fccf5e7"],
 ".",
 "\n"
}], "Usage",ExpressionUUID->"a7af9bdb-2796-45fa-906c-5ec3b9c26ce7"],

Cell[CellGroupData[{

Cell["Details and Options", "NotesSection",ExpressionUUID->"eb0fcb65-391c-47c4-9673-28c17fe39500"],

Cell[TextData[{
 "The renormalised one-loop determinant of a single Dirac fermion \
(first-order radial Dirac operator, adjacent Bessel orders); signed shell \
masses ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["M", "s"], "=", "m", "+", 
   RowBox[{"y", "\[ThinSpace]"}], 
   SubscriptBox["\[Phi]", "s"]}]], "InlineFormula",ExpressionUUID->
  "7f41cfbe-7eb7-40d5-8266-5c541a679ea1"],
 "."
}], "Notes",ExpressionUUID->"32152425-88db-465a-9aef-f74a9bf1b7a2"],

Cell[TextData[{
 "The marginal running is ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["\[Beta]", "\[Psi]"], "=", 
   SubsuperscriptBox["I", "2", "\[Psi]"], "+", 
   SubsuperscriptBox["I", "3", "\[Psi]"]}]], "InlineFormula",ExpressionUUID->
  "fe1b5d9e-bf58-48e8-9e78-870b6fc6967a"],
 " (both orders run, unlike the scalar's ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["I", "2"], "=", "0"}]], "InlineFormula",ExpressionUUID->
  "46f5e575-ae74-4c2e-8c35-13d7323f8613"],
 ")."
}], "Notes",ExpressionUUID->"cd5f6cb9-d0f7-492b-a056-404e98a29cad"],

