Cell["PolyDetIgPsi", "ObjectName",ExpressionUUID->"58855703-0e9b-44c3-b806-1540cc26c736"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{"PolyDetIgPsi", "[", 
   RowBox[{
    StyleBox["bf", "TI"], ",", 
    StyleBox["M", "TI"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "fcf1954a-5cfa-4048-82c0-df03922ad4e1"],
 "\[LineSeparator]",
 "the fermion gradient moment ",
 Cell[BoxData[
  SubsuperscriptBox["I", "g", "\[Psi]"]], "InlineFormula",ExpressionUUID->
  "23ddb10a-c95d-4dd3-9b48-c18158a4b9c4"],
 " = ",
 Cell[BoxData[
  RowBox[{"-", "\[Integral]", 
   SuperscriptBox["\[Rho]", 
    RowBox[{"D", "-", "1"}]], 
   SuperscriptBox[
    RowBox[{"(", 
     OverscriptBox["M", "."], ")"}], "2"]}]], "InlineFormula",ExpressionUUID->
  "1a44c02a-a491-446a-bd12-ec37dcc49e0e"],
 " on a BounceFunction (",
 StyleBox["M",
  FontSlant->"Italic"],
 " the signed fermion mass as a function of the field). ",
 "The wave-function running the first-order polygonal fermion determinant \
discards; the full ",
 "running is ",
 Cell[BoxData[
  RowBox[{"d", 
   SuperscriptBox["\[CapitalSigma]", "\[Psi]"], "/", "d", " ", "ln", 
   "\[Mu]"}]], "InlineFormula",ExpressionUUID->
  "e074f05d-cf01-4e5f-aa90-f61b4a98416e"],
 " = ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["\[Beta]", "\[Psi]"], "+", 
   SubsuperscriptBox["I", "g", "\[Psi]"]}]], "InlineFormula",ExpressionUUID->
  "e57e3b45-08c3-4bf1-9dc8-8f7a4de9b56b"],
 ", the fermion analogue of the gauge ",
 Cell[BoxData[
  SubsuperscriptBox["I", "3", "eff"]], "InlineFormula",ExpressionUUID->
  "fca3c5f8-ce7d-476b-83fe-e2549b850803"],
 " + ",
 Cell[BoxData[
  SubscriptBox["I", "g"]], "InlineFormula",ExpressionUUID->
  "67e5ed76-e7da-40a5-884f-f7e18fb185da"],
 ".",
 "\n"
}], "Usage",ExpressionUUID->"fcfe4c97-7c08-483e-bb23-86b2b9ee12eb"],

Cell[CellGroupData[{

Cell["Examples", "PrimaryExamplesSection",ExpressionUUID->"20d7a829-f4c9-461f-a959-aa4dd7866d18"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<PolyDet`\>\"", "]"}]], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"e6a9ed02-a187-4be1-8cb0-c51b9ebf4f75"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<FindBounce`\>\"", "]"}]], "Input",
 CellLabel->"In[2]:=",ExpressionUUID->"828169c7-09b9-4a3a-b712-6cf404424ca1"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"V", "[", "x_", "]"}], ":=", 
   RowBox[{
    RowBox[{
     FractionBox["1", "8"], " ", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox["x", "2"], "-", "1"}], ")"}], "2"]}], "+", 
    FractionBox[
     RowBox[{"x", "-", "1"}], "10"]}]}], ";", 
  RowBox[{"Vpp", "=", 
   RowBox[{
    RowBox[{
     FractionBox["1", "2"], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"3", " ", 
        SuperscriptBox["#1", "2"]}], "-", "1"}], ")"}]}], "&"}]}], 
  ";"}]], "Input",
 CellLabel->"In[3]:=",ExpressionUUID->"aca8cadb-9777-4490-929b-03d538318f7d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"tv", ",", "mid", ",", "fv"}], "}"}], "=", 
   RowBox[{"Sort", "[", 
    RowBox[{"Re", "[", 
     RowBox[{"x", "/.", "\[VeryThinSpace]", 
      RowBox[{"NSolve", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          SubscriptBox["\[PartialD]", "x"], 
          RowBox[{"V", "[", "x", "]"}]}], "\[Equal]", "0"}], ",", "x"}], 
       "]"}]}], "]"}], "]"}]}], ";", 
  RowBox[{"bf", "=", 
   RowBox[{"FindBounce", "[", 
    RowBox[{
     RowBox[{"V", "[", "x", "]"}], ",", "x", ",", 
     RowBox[{"{", 
      RowBox[{"fv", ",", "tv"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[4]:=",ExpressionUUID->"4b44ed81-afda-4df9-86c9-55e221d7c57a"],

Cell[BoxData[
 RowBox[{"PolyDetIgPsi", "[", 
  RowBox[{"bf", ",", 
   RowBox[{
    FractionBox[
     RowBox[{"7", " ", "#1"}], "10"], "&"}]}], "]"}]], "Input",
 CellLabel->"In[5]:=",ExpressionUUID->"59946570-dc7d-4f98-8a87-2f0122e2f2ee"]
}, Open  ]]
},
