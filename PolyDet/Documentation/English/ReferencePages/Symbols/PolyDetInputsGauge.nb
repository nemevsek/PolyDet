Cell[TextData[{
 Cell[BoxData[
  RowBox[{"PolyDetInputsGauge", "[", 
   RowBox[{
    StyleBox["bf", "TI"], ",", 
    StyleBox["g", "TI"], ",", 
    StyleBox["Vaa", "TI"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "45c36d74-34f0-4e05-b338-083ff6a0e773"],
 "\[LineSeparator]",
 "extracts ",
 Cell[BoxData[
  RowBox[{"{", 
   StyleBox["mA2",
    FontSlant->"Italic"], ",", 
   StyleBox["ma2",
    FontSlant->"Italic"], ",", 
   StyleBox["dmA",
    FontSlant->"Italic"], ",", 
   StyleBox["radii",
    FontSlant->"Italic"], "}"}]], "InlineFormula",ExpressionUUID->
  "66a54626-3ed5-48aa-8833-455b74f64854"],
 " from a BounceFunction for the U(1) Higgs gauge determinant (",
 Cell[BoxData[
  RowBox[{
   SubsuperscriptBox["m", "A", "2"], "=", 
   SuperscriptBox["g", "2"], 
   SuperscriptBox["\[Phi]", "2"]}]], "InlineFormula",ExpressionUUID->
  "d7230117-7bbf-4748-83a5-1c4e90ef0b0b"],
 ").",
 "\n"
}], "Usage",ExpressionUUID->"ad8ad905-e2c7-4d14-b7f8-096c44d101f1"],

