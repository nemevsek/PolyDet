Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<PolyDet`\>\"", "]"}]], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"b54c0cf3-4d3a-436a-94f0-fa7fd1e25415"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<FindBounce`\>\"", "]"}]], "Input",
 CellLabel->"In[2]:=",ExpressionUUID->"f5a7e0d6-3b65-4abe-9f28-0135053b4aff"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"V", "[", "x_", "]"}], ":=", 
   RowBox[{
    RowBox[{
     FractionBox["1", "8"], " ", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox["x", "2"], "-", "1"}], ")"}], "2"]}], "+", 
    FractionBox[
     RowBox[{"x", "-", "1"}], "10"]}]}], ";", 
  RowBox[{"Vpp", "=", 
   RowBox[{
    RowBox[{
     FractionBox["1", "2"], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"3", " ", 
        SuperscriptBox["#1", "2"]}], "-", "1"}], ")"}]}], "&"}]}], 
  ";"}]], "Input",
 CellLabel->"In[3]:=",ExpressionUUID->"fe08ae96-d8f1-443a-b86e-a0f3d0b5817a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"tv", ",", "mid", ",", "fv"}], "}"}], "=", 
   RowBox[{"Sort", "[", 
    RowBox[{"Re", "[", 
     RowBox[{"x", "/.", "\[VeryThinSpace]", 
      RowBox[{"NSolve", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          SubscriptBox["\[PartialD]", "x"], 
          RowBox[{"V", "[", "x", "]"}]}], "\[Equal]", "0"}], ",", "x"}], 
       "]"}]}], "]"}], "]"}]}], ";", 
  RowBox[{"bf", "=", 
   RowBox[{"FindBounce", "[", 
    RowBox[{
     RowBox[{"V", "[", "x", "]"}], ",", "x", ",", 
     RowBox[{"{", 
      RowBox[{"fv", ",", "tv"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[4]:=",ExpressionUUID->"f04589b0-44f4-461a-92cd-e6e230a6246c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"g", "=", 
   FractionBox["7", "10"]}], ";", 
  RowBox[{"gp", "=", 
   FractionBox["2", "5"]}], ";", 
  RowBox[{"Vaa", "=", 
   RowBox[{
    RowBox[{
     FractionBox["1", "2"], " ", 
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox["#1", "2"], "-", "1"}], ")"}]}], "&"}]}], 
  ";"}]], "Input",
 CellLabel->"In[5]:=",ExpressionUUID->"f187eebc-1312-4934-b251-37223e474bc1"],

Cell[BoxData[
 RowBox[{"PolyDetInputsGauge", "[", 
  RowBox[{"bf", ",", "g", ",", "Vaa"}], "]"}]], "Input",
 CellLabel->"In[6]:=",ExpressionUUID->"04ce3efa-d0e1-403b-8cc1-df76052fe94a"]
}, Open  ]]
