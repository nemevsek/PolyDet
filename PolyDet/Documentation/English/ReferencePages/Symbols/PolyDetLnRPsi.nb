Cell[TextData[{
 Cell[BoxData[
  RowBox[{"PolyDetLnRPsi", "[", 
   RowBox[{
    StyleBox["nu", "TI"], ",", 
    StyleBox["masses", "TI"], ",", 
    StyleBox["radii", "TI"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "34954ae7-9a53-4472-b523-540be6f56c16"],
 "\[LineSeparator]",
 "the Dirac-fermion log-ratio ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"ln", " "}], 
   SubsuperscriptBox["R", "\[Nu]", "\[Psi]"], "=", 
   RowBox[{"2", " ", "ln"}], "\[LeftBracketingBar]", 
   SubscriptBox["r", "\[Nu]"], "\[RightBracketingBar]"}]], "InlineFormula",
  ExpressionUUID->"df7c2cf3-702a-4edb-be0e-7e1126ef9013"],
 " (first-order adjacent-order Bessel chain; signed ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["M", "s"], "=", "m", "+", 
   RowBox[{"y", "\[ThinSpace]"}], 
   SubscriptBox["\[Phi]", "s"]}]], "InlineFormula",ExpressionUUID->
  "8c06b038-0ca2-4054-99c5-eac4cb49f7e8"],
 ").",
 "\n"
}], "Usage",ExpressionUUID->"cc6a668b-66a8-4244-98f0-8e14aa02aac1"],

