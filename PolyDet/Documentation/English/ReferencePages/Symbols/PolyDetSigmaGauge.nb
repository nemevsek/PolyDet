Cell["Options", "ExampleSection",ExpressionUUID->"98184954-d560-425d-9c5f-84f80d7a49e7"],

Cell[TextData[{
 "Override the gauge gradient ",
 Cell[BoxData[
  SubscriptBox["I", "g"]], "InlineFormula",ExpressionUUID->
  "26916073-ab4e-47c4-96fc-dbd976bded7f"],
 " with the continuum moment:"
}], "ExampleText",ExpressionUUID->"b7335475-c228-4e8d-a35f-733d7f9450f5"],

Cell[BoxData[
 RowBox[{"PolyDetSigmaGauge", "[", 
  RowBox[{"mA2", ",", "ma2", ",", "dmA", ",", "radii", ",", 
   RowBox[{"\"\<Ig\>\"", "\[Rule]", 
    RowBox[{"-", "540"}]}]}], "]"}]], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"79ce45a3-a756-4aee-942e-f299885c5300"],

Cell["Applications", "ExampleSection",ExpressionUUID->"169a46e4-7463-4fec-8d67-4fb63e474003"],

Cell[TextData[{
 "A genuine, self-consistent ",
 "U(1)",
 " Abelian-Higgs bounce. The scalar potential is a smooth double well in ",
 Cell[BoxData[
  RowBox[{"\[Sigma]", "=", 
   SubsuperscriptBox[
    RowBox[{"|", "\[CapitalPhi]", "|"}], "", "2"], "=", 
   SubsuperscriptBox["\[Phi]", "", "2"], "/", "2"}]], "InlineFormula",
  ExpressionUUID->"18cd74cb-53b0-4642-903d-6279069fde9c"],
 ", so the would-be Goldstone curvature ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["V", "aa"], "=", 
   RowBox[{
    StyleBox["V",
     FontSlant->"Italic"], "'"}], "/", "\[Phi]"}]], "InlineFormula",
  ExpressionUUID->"61f52d2b-3011-4cf6-ad1a-328cb76235de"],
 " is genuine (it vanishes at both vacua and turns tachyonic in the wall) and \
the gauge boson ",
 Cell[BoxData[
  SubsuperscriptBox["m", "A", "2"]], "InlineFormula",ExpressionUUID->
  "ea8be093-59d2-4953-8ce0-337b4f73d156"],
 " is massive in both vacua. Feed the FindBounce bounce straight in; the \
gradient ",
 Cell[BoxData[
  SubscriptBox["I", "g"]], "InlineFormula",ExpressionUUID->
  "b034105f-c441-447d-898d-ec0ea678a1d4"],
 " here is the converged moment ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"-", 
    SubsuperscriptBox["g", "", "2"]}], "\[Integral]", 
   SubsuperscriptBox["\[Rho]", "", "3"], 
   SubsuperscriptBox[
    OverscriptBox["\[Phi]", "."], "", "2"]}]], "InlineFormula",ExpressionUUID->
  "a8b304bd-5a2e-419a-9c5c-b108db327bcc"],
 ":"
}], "ExampleText",ExpressionUUID->"7298ae1a-e4a1-4417-aab4-8990b2f3989d"],

Cell[BoxData[
 RowBox[{"PolyDetSigmaGauge", "[", 
  RowBox[{
   RowBox[{"Sequence", "@@", 
    RowBox[{"PolyDetInputsGauge", "[", 
     RowBox[{"bfU", ",", "gU", ",", "VaaU"}], "]"}]}], ",", 
   RowBox[{"\"\<Ig\>\"", "\[Rule]", 
    RowBox[{"-", 
     FractionBox["277", "10"]}]}]}], "]"}]], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"30e961d7-a7ce-4510-9b41-78d87e7515a9"]
}, Open  ]]
