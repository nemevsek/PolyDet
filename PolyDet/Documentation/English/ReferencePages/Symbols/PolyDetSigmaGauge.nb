Cell["PolyDetSigmaGauge", "ObjectName",ExpressionUUID->"8e9490d4-eeac-4c60-af9a-81ef1bd8fabc"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{"PolyDetSigmaGauge", "[", 
   RowBox[{
    StyleBox["mA2", "TI"], ",", 
    StyleBox["ma2", "TI"], ",", 
    StyleBox["dmA", "TI"], ",", 
    StyleBox["radii", "TI"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "086a313c-c38d-4570-ad7d-b23ce9e2b6b8"],
 "\[LineSeparator]",
 "the assembled renormalised Abelian gauge-boson determinant (gauge masses ",
 Cell[BoxData[
  SubsuperscriptBox["m", "A", "2"]], "InlineFormula",ExpressionUUID->
  "bad6aac1-8a4f-4614-ba10-354e701a6c90"],
 ", ",
 Cell[BoxData[
  SubsuperscriptBox["m", "a", "2"]], "InlineFormula",ExpressionUUID->
  "e9fa93cf-604a-40a0-b9c2-bab9c0cbd481"],
 "): transverse + diagonal-Goldstone blocks with the ghost collapse, returned \
as ",
 Cell[BoxData[
  RowBox[{"\[LeftAssociation]", "\[CapitalSigma]", ",", 
   SubsuperscriptBox["I", "1", "eff"], ",", 
   SubsuperscriptBox["I", "3", "eff"], ",", 
   SubscriptBox["I", "g"], ",", 
   SubscriptBox["N", "sum"], "\[RightAssociation]"}]], "InlineFormula",
  ExpressionUUID->"afd19b9c-e07d-4f59-9b56-353d7d5321f0"],
 ".",
 "\n"
}], "Usage",ExpressionUUID->"9d046859-39b0-463d-a291-3ac003457a85"],

Cell[CellGroupData[{

Cell["Details and Options", "NotesSection",ExpressionUUID->"b9b411a0-358a-4c83-83ae-53a2ded161ed"],

Cell[TextData[{
 "Assembles the Abelian gauge determinant ",
 Cell[BoxData[
  SubscriptBox["\[CapitalSigma]", "gauge"]], "InlineFormula",ExpressionUUID->
  "3643b997-7119-42a1-9222-78c288fd227e"],
 " from the transverse and coupled diagonal-Goldstone blocks with the ghost \
collapse; returned as ",
 Cell[BoxData[
  RowBox[{"\[LeftAssociation]", "\[CapitalSigma]", ",", 
   SubsuperscriptBox["I", "1", "eff"], ",", 
   SubsuperscriptBox["I", "3", "eff"], ",", 
   SubscriptBox["I", "g"], ",", 
   SubscriptBox["N", "sum"], "\[RightAssociation]"}]], "InlineFormula",
  ExpressionUUID->"4709a07f-64e0-4456-b3f4-da5c381d680a"],
 "."
}], "Notes",ExpressionUUID->"1ff9d692-6979-4190-b226-5181e93cd09c"],

Cell[TextData[{
 "The bare value is scheme/\[Mu]-dependent \[LongDash] present the \
coefficients ",
 Cell[BoxData[
  SubsuperscriptBox["I", "1", "eff"]], "InlineFormula",ExpressionUUID->
  "5f486ea0-d4a9-491b-b8e0-825bb5c63ae5"],
 ", ",
 Cell[BoxData[
  SubsuperscriptBox["I", "3", "eff"]], "InlineFormula",ExpressionUUID->
  "cf646ecf-2ae1-4fce-91ff-4fb62ba53066"],
 ", ",
 Cell[BoxData[
  SubscriptBox["I", "g"]], "InlineFormula",ExpressionUUID->
  "eda610a4-2afc-4baa-b0bf-45b79100dc20"],
 " and the running rate ",
 Cell[BoxData[
  RowBox[{
   SubsuperscriptBox["I", "3", "eff"], "+", 
   SubscriptBox["I", "g"]}]], "InlineFormula",ExpressionUUID->
  "7b5a3a46-6c54-4d05-b437-10732d4062cd"],
 "."
}], "Notes",ExpressionUUID->"b53958d1-cbfd-48ea-967a-12e37500a6cb"],

