Cell[CellGroupData[{

Cell["Examples", "PrimaryExamplesSection",ExpressionUUID->"562504f0-4095-4312-98d9-f4f39c9c3514"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<PolyDet`\>\"", "]"}]], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"c9245391-433d-4e03-b8f1-57fea65d4ce9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"mA2", "=", 
   RowBox[{"{", 
    RowBox[{
     FractionBox["1", "2"], ",", 
     FractionBox["1", "5"], ",", "1", ",", 
     FractionBox["9", "10"]}], "}"}]}], ";", 
  RowBox[{"ma2", "=", 
   RowBox[{"{", 
    RowBox[{
     FractionBox["3", "2"], ",", 
     FractionBox["1", "5"], ",", "1", ",", 
     FractionBox["2", "5"]}], "}"}]}], ";", 
  RowBox[{"dmA", "=", 
   RowBox[{"{", 
    RowBox[{
     FractionBox["1", "2"], ",", 
     RowBox[{"-", 
      FractionBox["1", "5"]}], ",", 
     FractionBox["1", "10"]}], "}"}]}], ";", 
  RowBox[{"radii", "=", 
   RowBox[{"{", 
    RowBox[{"3", ",", "5", ",", "7"}], "}"}]}], ";"}]], "Input",
 CellLabel->"In[2]:=",ExpressionUUID->"4145f204-aa4e-477f-ae8c-dfc770f6a209"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<FindBounce`\>\"", "]"}]], "Input",
 CellLabel->"In[3]:=",ExpressionUUID->"b74b7ff9-5192-478f-909c-76eec53d1cd1"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Uu", "[", "s_", "]"}], ":=", 
   RowBox[{
    RowBox[{"6", " ", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"s", "-", 
        FractionBox["2", "25"]}], ")"}], "2"], " ", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"s", "-", 
        FractionBox["18", "25"]}], ")"}], "2"]}], "-", 
    RowBox[{
     FractionBox["3", "25"], " ", 
     RowBox[{"(", 
      RowBox[{"s", "-", 
       FractionBox["2", "25"]}], ")"}]}]}]}], ";"}]], "Input",
 CellLabel->"In[4]:=",ExpressionUUID->"be3372c0-62e6-4614-a9ee-021b4e3a9a37"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"VuU", "[", "ph_", "]"}], ":=", 
   RowBox[{"Uu", "[", 
    FractionBox[
     SuperscriptBox["ph", "2"], "2"], "]"}]}], ";", 
  RowBox[{"VppU", "=", 
   RowBox[{
    RowBox[{
     SuperscriptBox["VuU", "\[Prime]\[Prime]",
      MultilineFunction->None], "[", "#1", "]"}], "&"}]}], ";", 
  RowBox[{"VaaU", "=", 
   RowBox[{
    FractionBox[
     RowBox[{
      SuperscriptBox["VuU", "\[Prime]",
       MultilineFunction->None], "[", "#1", "]"}], "#1"], "&"}]}], ";", 
  RowBox[{"gU", "=", 
   FractionBox["7", "10"]}], ";"}]], "Input",
 CellLabel->"In[5]:=",ExpressionUUID->"3069c190-a65a-4a36-ab03-338bb27da9e6"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"fvU", ",", "tvU"}], "}"}], "=", 
   RowBox[{"MinMax", "[", 
    RowBox[{"ph", "/.", "\[VeryThinSpace]", 
     RowBox[{"Solve", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{
           SuperscriptBox["VuU", "\[Prime]",
            MultilineFunction->None], "[", "ph", "]"}], "\[Equal]", "0"}], 
         ",", 
         RowBox[{"ph", ">", "0"}]}], "}"}], ",", "ph", ",", 
       TemplateBox[{},
        "Reals"]}], "]"}]}], "]"}]}], ";", 
  RowBox[{"bfU", "=", 
   RowBox[{"FindBounce", "[", 
    RowBox[{
     RowBox[{"VuU", "[", "ph", "]"}], ",", "ph", ",", 
     RowBox[{"{", 
      RowBox[{"fvU", ",", "tvU"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[6]:=",ExpressionUUID->"ab2263e1-5fc4-41af-8c19-3a994f674807"],

Cell[BoxData[
 RowBox[{"PolyDetSigmaGauge", "[", 
  RowBox[{"mA2", ",", "ma2", ",", "dmA", ",", "radii"}], "]"}]], "Input",
 CellLabel->"In[7]:=",ExpressionUUID->"727f75a4-85a5-49f8-9b51-5ac877cbf8bf"]
}, Open  ]],

