     StyleBox["4", "InlineCode"]], "TableText",ExpressionUUID->
     "deb546bf-8c29-4af2-a97a-cbca9c23ff5f"], Cell[
    "the spacetime dimension D (3 or 4)", "TableText",ExpressionUUID->
     "277730e8-06f9-4d23-be49-8236ba3cdeca"]},
   {Cell["", "ModInfo",ExpressionUUID->
     "d290b7ed-6956-4e69-a501-6bb712c76526"], Cell[BoxData[
     StyleBox["WorkingPrecision", "InlineCode"]], "TableText",ExpressionUUID->
     "582b5625-713a-4a3d-9f34-eb26d3052258"], Cell[BoxData[
     StyleBox["Automatic", "InlineCode"]], "TableText",ExpressionUUID->
     "4a9dc988-d029-4fe1-b4bd-3769c323c6af"], Cell["\<\
the working precision (Automatic chooses machine vs scaled arbitrary \
precision)\
\>", "TableText",ExpressionUUID->"81ab4eb3-af48-4601-b195-ee6ca47228f5"]},
   {Cell["", "ModInfo",ExpressionUUID->
     "11558ed5-7278-444e-99e4-3174e3b82113"], Cell[BoxData[
     StyleBox["\"\<Nsum\>\"", "InlineCode"]], "TableText",ExpressionUUID->
     "4766cd15-cdc3-4b81-b240-99fff5c4333d"], Cell[BoxData[
     StyleBox["Automatic", "InlineCode"]], "TableText",ExpressionUUID->
     "d8ad4550-a4e6-45a9-b997-0047c10ee167"], Cell["\<\
the number of multipoles summed explicitly (Automatic: from Target, else ~5 \
x_max)\
\>", "TableText",ExpressionUUID->"6db2ac62-7150-4c09-9141-3dc1f1a5c0e6"]},
   {Cell["", "ModInfo",ExpressionUUID->
     "e5b35b1a-dc6a-4140-af1d-83d20d2796e0"], Cell[BoxData[
