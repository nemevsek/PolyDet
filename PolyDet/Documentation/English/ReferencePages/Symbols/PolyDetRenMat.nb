Cell["PolyDetRenMat", "ObjectName",ExpressionUUID->"6be560d6-9e19-4f71-8bc6-404cedaab3bf"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{"PolyDetRenMat", "[", 
   RowBox[{
    StyleBox["masses2", "TI"], ",", 
    StyleBox["radii", "TI"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d3a9aa51-75b1-4e4f-a682-24914e28063c"],
 "\[LineSeparator]",
 "the renormalised determinant for ",
 Cell[BoxData[
  SubscriptBox["N", "f"]], "InlineFormula",ExpressionUUID->
  "1c958d24-d0a5-4e12-92a5-9236db9b8f9b"],
 " coupled fields, with per-shell mass ",
 StyleBox["matrices",
  FontSlant->"Italic"],
 " ",
 StyleBox["masses2",
  FontSlant->"Italic"],
 " (zero-mode removal + Goldstones via options).",
 "\n"
}], "Usage",ExpressionUUID->"892e3bbb-3786-48a9-9a5a-9f4b98ecba9d"],

Cell[CellGroupData[{

Cell["Details and Options", "NotesSection",ExpressionUUID->"86ebde38-1516-4400-bfaf-e3366725704e"],

Cell[TextData[{
 "The matrix generalisation of PolyDetRen for ",
 Cell[BoxData[
  SubscriptBox["N", "f"]], "InlineFormula",ExpressionUUID->
  "3e84cff9-fd00-408e-b3ac-2fa1045cb6e5"],
 " coupled fields: each ",
 StyleBox["masses2",
  FontSlant->"Italic"],
 "[[s]] is an ",
 Cell[BoxData[
  SubscriptBox["N", "f"]], "InlineFormula",ExpressionUUID->
  "61645401-03bd-4e18-a153-9afe3e42d522"],
 "\[Times]",
 Cell[BoxData[
  SubscriptBox["N", "f"]], "InlineFormula",ExpressionUUID->
  "6039b9f3-4853-4901-974e-e89aeed68401"],
 " mass matrix; the UV subtraction is the flavour trace, no diagonalisation."
}], "Notes",ExpressionUUID->"8e33a7f6-405b-460e-b7b9-ebe34b4d5a46"],

Cell["\<\
Translational zero modes removed by default; a broken global symmetry adds \
Goldstones via the option.\
\>", "Notes",ExpressionUUID->"803562ea-d9f9-4a9b-8eb5-d56df1545366"],

Cell[BoxData[GridBox[{
   {Cell["", "ModInfo",ExpressionUUID->
     "a33221d0-2e90-418b-a3dc-3103877a1380"], Cell[BoxData[
     StyleBox["\"\<Scale\>\"", "InlineCode"]], "TableText",ExpressionUUID->
     "d36046bf-11ef-431d-a2cb-578c07d203bd"], Cell[BoxData[
     StyleBox["1", "InlineCode"]], "TableText",ExpressionUUID->
     "b47d2cbc-7a97-4fbc-ab67-8416b59f973d"], Cell[
    "the MS-bar renormalisation scale mu", "TableText",ExpressionUUID->
     "2933bac2-f5a4-45c0-a536-7cefca9f748e"]},
   {Cell["", "ModInfo",ExpressionUUID->
     "6dcf8435-c42a-4c3c-8727-ef2b4dbb4946"], Cell[BoxData[
     StyleBox["\"\<ZeroRemoval\>\"", "InlineCode"]], "TableText",
     ExpressionUUID->"6376b73f-ac7b-4d15-86c6-bface9a3dc54"], Cell[BoxData[
     StyleBox["True", "InlineCode"]], "TableText",ExpressionUUID->
     "46e62182-a3c3-4020-a63d-45a85ae61394"], Cell["\<\
remove the l=1 translational zero modes (via the reduced ratio R_1')\
\>", "TableText",ExpressionUUID->"417bb72d-bc73-423d-a8d7-768b404ec901"]},
   {Cell["", "ModInfo",ExpressionUUID->
     "5f54bc9b-d218-4e32-a873-f51ac9983b45"], Cell[BoxData[
     StyleBox["\"\<Goldstones\>\"", "InlineCode"]], "TableText",
     ExpressionUUID->"35df1468-b34a-470e-90cc-8459511ed111"], Cell[BoxData[
     StyleBox["0", "InlineCode"]], "TableText",ExpressionUUID->
     "9f5742c4-db0c-4fa3-968a-048c7f3a003a"], Cell["\<\
the number of broken-global-symmetry Goldstone zero modes to remove\
\>", "TableText",ExpressionUUID->"8b8089d4-52c8-4505-a47f-f3b22ee87904"]},
   {Cell["", "ModInfo",ExpressionUUID->
     "ac401cac-5a76-40cf-b8d0-86689536d400"], Cell[BoxData[
     StyleBox["\"\<Dimension\>\"", "InlineCode"]], "TableText",ExpressionUUID->
